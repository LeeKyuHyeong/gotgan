# 운영 환경변수 템플릿. 복사해서 .env.prod 로 채우고 절대 커밋하지 말 것.
#   cp .env.prod.example .env.prod && vi .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# --- DB (운영 MariaDB 컨테이너) ---
DB_ROOT_PASSWORD=change-me-strong-root-pw
DB_USERNAME=stock_app
DB_PASSWORD=change-me-strong-app-pw

# --- JWT (HS256, 최소 32바이트 이상 무작위) ---
# 생성 예: openssl rand -base64 48
JWT_SECRET=change-me-base64-48bytes-random
JWT_TTL=86400

# --- 카카오 ---
# REST API 키 (카카오 콘솔 > 앱 키 > REST API 키)
KAKAO_REST_API_KEY=
# Client Secret (보안 > Client Secret 사용 시). 안 쓰면 비워둠
KAKAO_CLIENT_SECRET=
# 운영 Redirect URI — 카카오 콘솔에도 동일하게 등록해야 함
KAKAO_REDIRECT_URI=https://gotgan.kyuhyeong.com/oauth/kakao/callback

# --- CORS (운영 프론트 도메인) ---
CORS_ORIGINS=https://gotgan.kyuhyeong.com

# --- Web Push (곧만료 알림, VAPID) ---
# 키쌍 생성: npx web-push generate-vapid-keys
# 공개키는 프론트로도 나가는 값이지만 키쌍 자체는 운영 전용으로 유지(로컬 기본키와 분리).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
PUSH_SUBJECT=mailto:rbgud2380@naver.com
